# ============================================================================
# Agentic Takım — Ortam Değişkenleri (örnek)
# Bu dosyayı .env olarak kopyalayın: `cp .env.example .env`
# .env ASLA commit edilmez (bkz. .gitignore).
# ============================================================================

# --- Compose / proje ---
COMPOSE_PROJECT_NAME=agentic

# --- PostgreSQL (tek instance, iki database: agentic_os + langfuse) ---
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic_dev_pw
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agentic_os
# Control-plane / agent-runner bağlantısı (container içi host = postgres)
DATABASE_URL=postgresql+asyncpg://agentic:agentic_dev_pw@postgres:5432/agentic_os

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- NATS (JetStream) ---
NATS_HOST=nats
NATS_PORT=4222
NATS_URL=nats://nats:4222

# --- Qdrant (memory profili) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agent_memory

# --- LiteLLM (ai profili) ---
LITELLM_PORT=4000
LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-local-master-dev
# Sağlayıcı anahtarları — boş bırakılabilir; boşsa LLM_AVAILABLE=False ile çalışır.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Langfuse (observability profili) ---
LANGFUSE_PORT=3001
LANGFUSE_URL=http://langfuse:3000
LANGFUSE_DB=langfuse
NEXTAUTH_SECRET=change-me-langfuse-secret
SALT=change-me-langfuse-salt
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- OpenTelemetry (observability profili) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=agentic-control-plane

# --- Feature flags (graceful degradation; setup tarafından ayarlanır) ---
LLM_AVAILABLE=false
MEMORY_AVAILABLE=false
OBSERVABILITY_AVAILABLE=false

# --- Uygulama portları (host) ---
WEB_PORT=3000
CONTROL_PLANE_PORT=8000

# --- Web (tarayıcıdan control-plane'e erişim) ---
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:8000

# --- Tool Runtime (v1.1 — boş bırakılırsa SimulatedAdapter'a fallback) ---
TOOL_RUNTIME_PORT=8001
ERP_BASE_URL=
ERP_API_KEY=
ERP_PROVIDER=bizimhesap
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Observer (v1.3 — post-hoc analytics plane, read-only) ---
OBSERVER_PORT=8002
OBSERVER_INTERNAL_TOKEN=dev-internal-token
