{
  "$comment": "Tool kataloğu (v1.1-a). adapter_class → hangi adaptör kullanılacak. secrets eksikse SimulatedAdapter'a fallback.",
  "tools": {
    "check_stock": {
      "args_schema": {"sku": "string", "qty": "int"},
      "permission": "read",
      "adapter_class": "ERPAdapter",
      "timeout_ms": 10000,
      "side_effect": false,
      "compensation": null,
      "rate_limit": {"per_minute": 30, "per_task": 10}
    },
    "create_quote": {
      "args_schema": {"customer": "string", "items": "list"},
      "permission": "write",
      "adapter_class": "ERPAdapter",
      "timeout_ms": 15000,
      "side_effect": true,
      "compensation": "cancel_create_quote",
      "rate_limit": {"per_minute": 10, "per_task": 3}
    },
    "generate_pdf": {
      "args_schema": {"quote_id": "string"},
      "permission": "write",
      "adapter_class": "ERPAdapter",
      "timeout_ms": 15000,
      "side_effect": false,
      "compensation": null,
      "rate_limit": {"per_minute": 20, "per_task": 5}
    },
    "send_whatsapp": {
      "args_schema": {"to": "string", "doc": "string"},
      "permission": "external_send",
      "adapter_class": "WhatsAppAdapter",
      "timeout_ms": 20000,
      "requires_approval": true,
      "side_effect": true,
      "compensation": null,
      "rate_limit": {"per_minute": 5, "per_task": 1}
    },
    "drop_table": {
      "args_schema": {"table": "string"},
      "permission": "danger",
      "adapter_class": "SimulatedAdapter",
      "timeout_ms": 5000,
      "side_effect": true,
      "compensation": null,
      "rate_limit": {"per_minute": 2, "per_task": 1}
    }
  },
  "permissions": {
    "$comment": "Bir tool'u çağırabilmek için gereken izinler.",
    "allow": ["read", "write", "external_send"]
  }
}
